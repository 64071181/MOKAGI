
# ===========================================
# ===========================================
# ================== 必看 ===================
# 鍵=值(不要有空格、""、''，以換行分隔。修改後需要重啟 Agent 才會生效。)
# 管理員 Chat ID（tg版）*必要*
# ===========================================
# ===========================================






# ================== 用戶信息 ===================

ADMIN_NAME=用戶

# 管理員 Chat ID（網頁版）
MOK_ADMIN_CHAT_ID=any






# ================== agent信息 ===================
# agent名稱
MOK_AGENT_NAME=__MOK_AGENT_NAME_PLACEHOLDER__
MOK_AGENT_ICON=🤖

# 語氣風格: 像朋友一樣
MOK_AGENT_SPEAKING_STYLE=像朋友一樣

# 慣用語言: 繁體中文
MOK_AGENT_COMMON_LANGUAGE=繁體中文












# ================== agent固定臺詞 ===================
MOK_start_msg=新對話開始了！有什麼我可以幫忙的嗎？😊
MOK_welcome_msg=歡迎回來！上次我們聊到哪了？需要我幫你回顧一下嗎？😉
MOK_unAllowed_msg=你好！很抱歉，你目前沒有使用這個機器人的權限。如果你需要使用，請聯繫管理員。謝謝！🙏







# ================== 通訊軟件 ===================

# 管理員 Chat ID（tg版）*必要*
ADMIN_CHAT_ID=

# 允許使用機器人的用戶 ID，多個用英文逗號分隔 (留空則所有人可用)
MOK_ALLOWED_USERS=

# Telegram Bot Token
MOK_TG_TOKEN=









# ================== 模型設定 ===================
# 這裡指定 Ollama 本機已下搭載模型名稱，可在 https://ollama.com/qwen3:1.7b 直接找其他模型
# Ollama API 端點 = http://localhost:11434/api/generate (token=留空)
# OpenAI 客户端 = http://localhost:11434/v1  (token=必須)

# openrouter 客户端 = https://openrouter.ai/api/v1
# https://openrouter.ai/settings/privacy Free endpoints that may train on request data、Free endpoints that may publish prompts = on

MOK_MODEL_NAME=qwen3:1.7b
MOK_MODEL_url=http://localhost:11434/api/generate
MOK_MODEL_token=

MOK_MODEL_NAME2=nvidia/nemotron-3-super-120b-a12b:free
MOK_MODEL_url2=https://openrouter.ai/api/v1
MOK_MODEL_token2=



# 當前激活的模型（可以是上面的任意一個名稱）
MOK_CURRENT_MODEL=qwen3:1.7b








# ================== 模型參數 ===================
MOK_MAX_HISTORY_ROUNDS=6
# 對話歷史保留輪數，過多會增加上下文長度，過少則無記憶感

MOK_num_ctx=163840
# 模型的上下文視窗大小(如 8192、16384）(32768 = 約 2.2 萬個中文字 / 40 到 50 頁 A4 紙滿滿的文字量）

MOK_num_predict=8192
# 模型的最大生成長度(如 2048、4096、8192）(8192 = 5,400 中文字 / 6 頁 A4 紙滿滿的文字量)

MOK_temperature=0.8
# 溫度 / 隨機性(0 嚴謹, 1.0+ 創意)

MOK_repeat_penalty=1.5
# 重複懲罰，防止鬼打牆(1.0:不懲罰，2.0:太高)

MOK_presence_penalty=0.6
# 字重複施加懲罰。正值增加新詞可能性，負值鼓勵重複

MOK_frequency_penalty=0.5
# 字出現頻率施加懲罰，正值減少重複，負值鼓勵重複

MOK_top_p=0.9
# top_p  = 當 AI 準備說下一個字時，它會給所有可能的字打分數(機率）。0.1 = 這會讓說話非常嚴謹、死板、重複性高。0.9 = AI 會考慮總和達到 90% 的大量候選字。這會讓說話非常豐富、有創意、出人意料。

MOK_top_k=50
# top_k  = 當 AI 準備說下一個字時，它會給所有可能的字打分數(機率）。top_k=50 會讓 AI 只考慮分數最高的 50 個字。這會讓說話更嚴謹、重複性高，但仍有一定變化。top_k=0 則不限制候選字數量，完全由 temperature 和 top_p 控制隨機性。







# ================== 自動記憶檢索 ===================
MOK_MEMORY_RECALL_COUNT=50
# 數字越大，每次對話會取越多條記憶（建議 1~3）。重啟後生效。








# ================== Ollama設定 ===================
MOK_NUM_THREADS=2
# Ollama 允許的最大 CPU 執行緒數，根據你的 CPU 核心數調整(如 2、4、8）











# ================== 搜尋 KEY ===================
TAVILY_API_KEY=



























































